    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\n\nif (!data.tasks) {\n  data.tasks = [];\n}\n\nconst taskText = $json.body.task;\n\nconst newTask = {\n  id: data.tasks.length + 1,\n  task: taskText,\n  done: false\n};\n\ndata.tasks.push(newTask);\n\nreturn [\n{\njson: newTask\n}\n];"
      },
