    {
      "parameters": {
        "jsCode": "const data = $getWorkflowStaticData('global');\n\n// garante que a lista existe\nif (!data.tasks) {\n  data.tasks = [];\n}\n\nconst id = $json.body?.id;\n\n// procura a tarefa\nconst task = data.tasks.find(t => t.id === id);\n\nif (!task) {\n  return [\n    {\n      json: {\n        error: \"Task not found\"\n      }\n    }\n  ];\n}\n\ntask.done = true;\n\nreturn [\n  {\n    json: task\n  }\n];"
      },
